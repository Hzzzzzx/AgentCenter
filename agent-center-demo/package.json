{
  "name": "agent-center-demo",
  "version": "1.0.0",
  "description": "AgentCenter MVP Demo - 对话驱动 DevOps 演示",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "test:e2e": "playwright test",
    "test:server": "node -e \"const{spawn}=require('child_process');const s=spawn('node',['server/index.js'],{stdio:'pipe'});s.stdout.on('data',d=>{if(d.toString().includes('4000')){const t=spawn('npx',['playwright','test'],{stdio:'inherit'});t.on('exit',c=>{s.kill();process.exit(c)})}})\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "playwright": "^1.59.1"
  }
}
